# ── Data layer ────────────────────────────────────────────────
# Default repo is seed JSON (/data). Set USE_SUPABASE=true to swap.
USE_SUPABASE=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM agent (Groq, free tier) ──────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Routing (free tier) ──────────────────────────────────────
# OpenRouteService (free key) or leave blank to use public OSRM demo.
OPENROUTESERVICE_API_KEY=
OSRM_BASE_URL=https://router.project-osrm.org

# ── Live event ingest (Phase 3, all free tier) ───────────────
EVENTBRITE_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=matchday-ingest/0.1
